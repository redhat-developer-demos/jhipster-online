FROM registry.redhat.io/ubi8/openjdk-17@sha256:af305e087061cbaa4107ce0b304a1ef987f6b54bae3f75bfd529cfd084cba9b5 AS builder

USER root

RUN microdnf install -y unzip

WORKDIR /usr/share/maven
RUN rm -rf /usr/share/maven/* /usr/bin/mvn
RUN curl -L -o apache-maven-3.9.15-bin.zip https://dlcdn.apache.org/maven/maven-3/3.9.15/binaries/apache-maven-3.9.15-bin.zip && \
    unzip apache-maven-3.9.15-bin.zip "apache-maven-3.9.15/*" -d "/usr/share/maven" && \
    ln -s /usr/share/maven/apache-maven-3.9.15/bin/mvn /usr/bin/mvn && \
    rm -rf apache-maven-3.9.15-bin.zip

ENV MAVEN_VERSION=3.9.15
ENV MAVEN_OPTS="-Xmx3489m"
ENV M2_HOME=/usr/share/maven/apache-maven-3.9.15
ENV PATH=$PATH:/usr/share/maven/apache-maven-3.9.15/bin

ENV NODE_VERSION=22.19.0
ENV PATH="/usr/local/bin:${PATH}"
RUN microdnf install -y tar xz gzip curl git && \
    ARCH=$(uname -m) && \
    case "$ARCH" in x86_64) NODE_ARCH=x64 ;; aarch64) NODE_ARCH=arm64 ;; ppc64le) NODE_ARCH=ppc64le ;; s390x) NODE_ARCH=s390x ;; *) echo "unsupported arch: $ARCH"; exit 1 ;; esac && \
    curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz" -o /tmp/node.tar.xz && \
    tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 && \
    rm -f /tmp/node.tar.xz && \
    npm install -g yarn && \
    microdnf clean all

WORKDIR /build
COPY . .
RUN yarn install --frozen-lockfile --ignore-scripts && \
    mvn -ntp package -Pprod -Dmaven.test.skip=true -DskipTests

# --- Runtime ---
FROM registry.redhat.io/ubi8/openjdk-17@sha256:af305e087061cbaa4107ce0b304a1ef987f6b54bae3f75bfd529cfd084cba9b5

USER root

ENV NODE_VERSION=22.19.0
ENV PATH="/usr/local/bin:${PATH}"
RUN microdnf install -y tar xz gzip curl git && \
    ARCH=$(uname -m) && \
    case "$ARCH" in x86_64) NODE_ARCH=x64 ;; aarch64) NODE_ARCH=arm64 ;; ppc64le) NODE_ARCH=ppc64le ;; s390x) NODE_ARCH=s390x ;; *) echo "unsupported arch: $ARCH"; exit 1 ;; esac && \
    curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz" -o /tmp/node.tar.xz && \
    tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 && \
    rm -f /tmp/node.tar.xz && \
    npm install -g yarn generator-jhipster@9.0.0 && \
    microdnf clean all

COPY --from=builder /build/target/jhonline-*.war /deployments/

USER 1001
